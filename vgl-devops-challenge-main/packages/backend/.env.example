# Backend environment configuration
# Driver can be 'sqlite' or 'mysql'
DB_DRIVER=sqlite

# SQLite settings (used when DB_DRIVER=sqlite)
DB_PATH=data/dev.db

# MySQL Production settings (used when DB_DRIVER=mysql)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=app
DB_USER=app
DB_PASS=change-me

# Server
HTTP_HOST=0.0.0.0
HTTP_PORT=8080

# Response cache (Redis)
# Set REDIS_CACHE_ENABLED=1 to enable cache reads.
REDIS_CACHE_ENABLED=0
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TIMEOUT=0.05
